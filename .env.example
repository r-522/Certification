# Supabase PostgreSQL connection string (use pgbouncer URL for serverless)
# Format: postgresql://postgres:[password]@db.[project-ref].supabase.co:6543/postgres?pgbouncer=true
DATABASE_URL=postgresql://postgres:password@db.xxxxxxxxxxxx.supabase.co:6543/postgres?pgbouncer=true

# HMAC secret for deterministic email hashing (min 32 chars, store securely)
EMAIL_HMAC_SECRET=your-very-long-and-random-secret-key-here
